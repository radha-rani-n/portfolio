---
import RadhaPhoto from "../assets/headshot_processed.jpg";
---

<section class="min-h-screen flex items-center" id="home">
  <div class="max-w-[1280px] mx-auto px-6 md:px-8 w-full pt-28 md:pt-32 pb-16 md:pb-20">
    <div class="flex flex-col-reverse md:grid md:grid-cols-2 gap-10 md:gap-16 items-center">
      <!-- Left: Content -->
      <div class="flex flex-col gap-4 md:gap-5 text-center md:text-left">
        <p class="text-[var(--first-color)] text-sm uppercase tracking-[0.2em] font-medium animate-fade-in-up delay-100">
          Software Developer
        </p>

        <h1 class="text-4xl md:text-5xl font-bold leading-tight text-[var(--title-color)] animate-fade-in-up delay-200">
          Hi, I'm Radha
        </h1>

        <p class="text-base md:text-lg text-[var(--text-color)] leading-relaxed animate-fade-in-up delay-300">
          I'm a Fullstack Developer who builds web applications that solve real
          problems for real people — from intuitive React interfaces to reliable
          APIs and databases. I combine a supply chain analyst's eye for systems
          thinking with a modern AI-augmented workflow to ship clean, purposeful
          software that genuinely helps users.
        </p>

        <div class="flex items-center gap-3 mt-2 animate-fade-in-up delay-400 justify-center md:justify-start flex-wrap">
          <a
            href="#contact"
            class="px-5 md:px-6 py-3 rounded-lg bg-[var(--first-color)] text-white font-medium inline-flex items-center gap-2 btn-hover"
          >
            Get in Touch <i class="uil uil-arrow-right"></i>
          </a>
          <a
            href="#projects"
            class="px-5 md:px-6 py-3 rounded-lg border border-gray-300 text-[var(--title-color)] font-medium hover:border-[var(--first-color)] hover:text-[var(--first-color)] transition-all duration-300"
          >
            View Projects
          </a>
        </div>

        <div class="flex items-center gap-5 mt-2 animate-fade-in-up delay-500 justify-center md:justify-start">
          <a href="https://www.linkedin.com/in/radha-rani-n/" target="_blank" class="text-[var(--text-color)] hover:text-[var(--first-color)] transition-colors duration-300">
            <i class="uil uil-linkedin-alt text-2xl"></i>
          </a>
          <a href="https://github.com/radha-rani-n" target="_blank" class="text-[var(--text-color)] hover:text-[var(--first-color)] transition-colors duration-300">
            <i class="uil uil-github-alt text-2xl"></i>
          </a>
        </div>
      </div>

      <!-- Right: Photo -->
      <div class="flex justify-center animate-fade-in-right delay-300">
        <img
          src={RadhaPhoto.src}
          alt="Radha Rani"
          class="w-[220px] h-[270px] md:w-[350px] md:h-[420px] object-cover rounded-2xl shadow-lg"
        />
      </div>
    </div>
  </div>
</section>
