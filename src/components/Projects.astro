---
import VoyaVideo from "../assets/voya-demo.mov";
import LetsSwapImg from "../assets/lets-swap-image.png";
import TodoList from "../assets/TodoList.png";
import CoTeacher from "../assets/CO-Teacher.png";
---

<section class="flex items-center justify-center flex-col pt-20 md:pt-24 my-12 md:my-16 px-6 md:px-0" id="projects">
  <div class="reveal flex flex-col items-center gap-4 mb-6 md:mb-8">
    <h2 class="text-3xl md:text-4xl font-bold section-heading">Projects</h2>
    <p class="text-[var(--text-color)]">What I've built</p>
  </div>

  <!-- Project 1: Let's Swap -->
  <article class="project-card w-full flex flex-col md:grid md:grid-cols-2 my-6 md:my-10 gap-8 md:gap-16 items-center p-6 md:p-8 rounded-2xl">
    <div class="project-img-wrapper bg-[var(--first-color-lighter)] p-4 w-full h-[220px] md:h-[300px] reveal-left">
      <img src={LetsSwapImg.src} alt="Let's Swap App" class="w-full rounded-xl h-full object-cover" />
    </div>
    <div class="flex flex-col gap-4 md:gap-6 reveal-right">
      <div class="flex items-center gap-3">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--first-color)] bg-[var(--first-color-lighter)]/40 px-3 py-1 rounded-full">FullStack</p>
      </div>
      <h3 class="text-2xl md:text-3xl font-bold">Let's Swap</h3>
      <p class="leading-relaxed text-[var(--text-color)] text-sm md:text-base">
        A plant trading community app where users can list and swap plants
        with others nearby. Features real-time chat, location-based listings,
        and distance filtering — built for plant lovers who want to grow their
        collection without spending money.
      </p>
      <ul class="flex gap-2 flex-wrap">
        <li class="tech-tag px-3 py-1 bg-[var(--first-color-lighter)] rounded-full text-[var(--first-color-alt)] text-xs font-medium cursor-default">TypeScript</li>
        <li class="tech-tag px-3 py-1 bg-[var(--first-color-lighter)] rounded-full text-[var(--first-color-alt)] text-xs font-medium cursor-default">React</li>
        <li class="tech-tag px-3 py-1 bg-[var(--first-color-lighter)] rounded-full text-[var(--first-color-alt)] text-xs font-medium cursor-default">Tailwind</li>
        <li class="tech-tag px-3 py-1 bg-[var(--first-color-lighter)] rounded-full text-[var(--first-color-alt)] text-xs font-medium cursor-default">Express</li>
        <li class="tech-tag px-3 py-1 bg-[var(--first-color-lighter)] rounded-full text-[var(--first-color-alt)] text-xs font-medium cursor-default">PostgreSQL</li>
        <li class="tech-tag px-3 py-1 bg-[var(--first-color-lighter)] rounded-full text-[var(--first-color-alt)] text-xs font-medium cursor-default">Prisma</li>
      </ul>
      <div class="flex gap-3 flex-wrap">
        <a
          href="https://lets-swap.vercel.app/"
          target="_blank"
          class="explorer-btn px-5 md:px-6 py-3 bg-[var(--first-color-alt)] rounded-full text-white w-fit font-bold btn-hover inline-flex items-center gap-2 text-sm md:text-base"
          ><i class="uil uil-external-link-alt text-lg"></i> Live Demo<i class="uil uil-arrow-up-right ml-1"></i></a
        >
        <a
          href="https://github.com/radha-rani-n/lets-swap"
          target="_blank"
          class="px-5 md:px-6 py-3 rounded-full border-2 border-[var(--first-color-alt)] text-[var(--first-color-alt)] w-fit font-bold btn-hover inline-flex items-center gap-2 text-sm md:text-base hover:bg-[var(--first-color-alt)] hover:text-white transition-colors duration-300"
          ><i class="uil uil-github-alt text-lg"></i> GitHub</a
        >
      </div>
    </div>
  </article>

  <!-- Project 2: Voya -->
  <article class="project-card w-full flex flex-col-reverse md:grid md:grid-cols-2 my-6 md:my-10 gap-8 md:gap-16 items-center p-6 md:p-8 rounded-2xl">
    <div class="flex flex-col gap-4 md:gap-6 reveal-left">
      <div class="flex items-center gap-3">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--first-color)] bg-[var(--first-color-lighter)]/40 px-3 py-1 rounded-full">FullStack</p>
      </div>
      <h3 class="text-2xl md:text-3xl font-bold">Voya — Travel Planner</h3>
      <p class="leading-relaxed text-[var(--text-color)] text-sm md:text-base">
        A fullstack travel planning app where users can search destinations,
        browse popular attractions, and organize trips — all in one place.
        Built with a TypeScript + React frontend and an Express/Knex/Postgres
        backend with RESTful API endpoints.
      </p>
      <ul class="flex gap-2 flex-wrap">
        <li class="tech-tag px-3 py-1 bg-[var(--first-color-lighter)] rounded-full text-[var(--first-color-alt)] text-xs font-medium cursor-default">TypeScript</li>
        <li class="tech-tag px-3 py-1 bg-[var(--first-color-lighter)] rounded-full text-[var(--first-color-alt)] text-xs font-medium cursor-default">React</li>
        <li class="tech-tag px-3 py-1 bg-[var(--first-color-lighter)] rounded-full text-[var(--first-color-alt)] text-xs font-medium cursor-default">Sass</li>
        <li class="tech-tag px-3 py-1 bg-[var(--first-color-lighter)] rounded-full text-[var(--first-color-alt)] text-xs font-medium cursor-default">Express</li>
        <li class="tech-tag px-3 py-1 bg-[var(--first-color-lighter)] rounded-full text-[var(--first-color-alt)] text-xs font-medium cursor-default">Knex</li>
        <li class="tech-tag px-3 py-1 bg-[var(--first-color-lighter)] rounded-full text-[var(--first-color-alt)] text-xs font-medium cursor-default">Postgres</li>
      </ul>
      <a
        href="https://github.com/radha-rani-n/radha-rani-nathibayannagari-voya"
        target="_blank"
        class="explorer-btn px-5 md:px-6 py-3 bg-[var(--first-color-alt)] rounded-full text-white w-fit font-bold btn-hover inline-flex items-center gap-2 text-sm md:text-base"
        ><i class="uil uil-github-alt text-lg"></i> View on GitHub<i class="uil uil-arrow-up-right ml-1"></i></a
      >
    </div>
    <div class="reveal-right w-full h-[220px] md:h-[300px]">
      <div class="video-thumbnail rounded-xl overflow-hidden shadow-lg border border-gray-200 h-full flex flex-col cursor-pointer relative group" data-video-src={VoyaVideo}>
        <div class="bg-gray-100 px-4 py-2 flex items-center gap-3 border-b border-gray-200 shrink-0">
          <div class="flex gap-1.5">
            <span class="w-2.5 h-2.5 rounded-full bg-red-400"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-yellow-400"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-green-400"></span>
          </div>
          <div class="flex-1 bg-white rounded-md px-3 py-1 text-xs text-gray-400 truncate">voya-travel.app</div>
        </div>
        <div class="absolute inset-0 flex items-center justify-center bg-black/0 group-hover:bg-black/20 transition-all duration-300 z-10 pointer-events-none">
          <div class="w-14 h-14 rounded-full bg-white/90 flex items-center justify-center shadow-lg opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <i class="uil uil-expand-arrows text-[var(--first-color)] text-2xl"></i>
          </div>
        </div>
        <video src={VoyaVideo} autoplay muted loop playsinline class="demo-video w-full flex-1 object-cover object-top"></video>
      </div>
    </div>
  </article>

  <!-- Project 3: Co-Teacher -->
  <article class="project-card w-full flex flex-col md:grid md:grid-cols-2 my-6 md:my-10 gap-8 md:gap-16 items-center p-6 md:p-8 rounded-2xl">
    <div class="project-img-wrapper bg-[var(--first-color-lighter)] p-4 w-full h-[220px] md:h-[300px] reveal-left">
      <img src={CoTeacher.src} alt="Co-Teacher App" class="w-full rounded-xl h-full object-cover" />
    </div>
    <div class="flex flex-col gap-4 md:gap-6 reveal-right">
      <div class="flex items-center gap-3">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--first-color)] bg-[var(--first-color-lighter)]/40 px-3 py-1 rounded-full">FullStack</p>
        <p class="text-xs font-semibold uppercase tracking-widest text-amber-600 bg-amber-100 px-3 py-1 rounded-full">Hackathon Winner</p>
      </div>
      <h3 class="text-2xl md:text-3xl font-bold">Co-Teacher — AI Education Tool</h3>
      <p class="leading-relaxed text-[var(--text-color)] text-sm md:text-base">
        An AI-powered assistant that helps students develop critical thinking
        and responsible AI usage skills. Built end-to-end in a team during the
        BrainStation x Microsoft Industry Project — awarded <strong class="text-[var(--title-color)]">first place</strong> out
        of all competing teams.
      </p>
      <ul class="flex gap-2 flex-wrap">
        <li class="tech-tag px-3 py-1 bg-[var(--first-color-lighter)] rounded-full text-[var(--first-color-alt)] text-xs font-medium cursor-default">JavaScript</li>
        <li class="tech-tag px-3 py-1 bg-[var(--first-color-lighter)] rounded-full text-[var(--first-color-alt)] text-xs font-medium cursor-default">React</li>
        <li class="tech-tag px-3 py-1 bg-[var(--first-color-lighter)] rounded-full text-[var(--first-color-alt)] text-xs font-medium cursor-default">Sass</li>
        <li class="tech-tag px-3 py-1 bg-[var(--first-color-lighter)] rounded-full text-[var(--first-color-alt)] text-xs font-medium cursor-default">Express</li>
      </ul>
      <a
        href="https://github.com/parisrahmani/Microsoft-Hackathon-Client"
        target="_blank"
        class="explorer-btn px-5 md:px-6 py-3 bg-[var(--first-color-alt)] rounded-full text-white w-fit font-bold btn-hover inline-flex items-center gap-2 text-sm md:text-base"
        ><i class="uil uil-github-alt text-lg"></i> View on GitHub<i class="uil uil-arrow-up-right ml-1"></i></a
      >
    </div>
  </article>

  <!-- Project 4: TodoList -->
  <article class="project-card w-full flex flex-col md:grid md:grid-cols-2 my-6 md:my-10 gap-8 md:gap-16 items-center p-6 md:p-8 rounded-2xl">
    <div class="project-img-wrapper bg-[var(--first-color-lighter)] p-4 w-full h-[220px] md:h-[300px] reveal-left">
      <img src={TodoList.src} alt="TodoList App" class="w-full rounded-xl h-full object-cover" />
    </div>
    <div class="flex flex-col gap-4 md:gap-6 reveal-right">
      <div class="flex items-center gap-3">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--first-color)] bg-[var(--first-color-lighter)]/40 px-3 py-1 rounded-full">FullStack</p>
      </div>
      <h3 class="text-2xl md:text-3xl font-bold">TaskFlow — Todo App</h3>
      <p class="leading-relaxed text-[var(--text-color)] text-sm md:text-base">
        A fullstack task management app with complete CRUD functionality.
        Built with a React frontend and Express API backend, featuring a
        clean responsive UI. Developed in a 3-hour pair programming sprint —
        demonstrating rapid prototyping and collaboration skills.
      </p>
      <ul class="flex gap-2 flex-wrap">
        <li class="tech-tag px-3 py-1 bg-[var(--first-color-lighter)] rounded-full text-[var(--first-color-alt)] text-xs font-medium cursor-default">JavaScript</li>
        <li class="tech-tag px-3 py-1 bg-[var(--first-color-lighter)] rounded-full text-[var(--first-color-alt)] text-xs font-medium cursor-default">React</li>
        <li class="tech-tag px-3 py-1 bg-[var(--first-color-lighter)] rounded-full text-[var(--first-color-alt)] text-xs font-medium cursor-default">Sass</li>
        <li class="tech-tag px-3 py-1 bg-[var(--first-color-lighter)] rounded-full text-[var(--first-color-alt)] text-xs font-medium cursor-default">Express</li>
      </ul>
      <a
        href="https://github.com/radha-rani-n/Todolist-client-latest"
        target="_blank"
        class="explorer-btn px-5 md:px-6 py-3 bg-[var(--first-color-alt)] rounded-full text-white w-fit font-bold btn-hover inline-flex items-center gap-2 text-sm md:text-base"
        ><i class="uil uil-github-alt text-lg"></i> View on GitHub<i class="uil uil-arrow-up-right ml-1"></i></a
      >
    </div>
  </article>
</section>

<!-- Shared lightbox (outside project cards) -->
<div id="video-lightbox" class="fixed inset-0 z-[200] hidden items-center justify-center bg-black/85 p-6 md:p-16">
  <button id="lightbox-close" class="absolute top-5 right-5 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white text-2xl cursor-pointer transition-colors z-10">
    <i class="uil uil-times"></i>
  </button>
  <video id="lightbox-video" autoplay muted loop playsinline controls class="max-w-[90vw] max-h-[85vh] rounded-xl shadow-2xl"></video>
</div>

<style>
  .project-card {
    transition: box-shadow 0.4s ease, transform 0.4s ease;
    border: 1px solid transparent;
  }
  .project-card:hover {
    box-shadow: 0 16px 48px rgba(110, 87, 224, 0.08);
    border-color: var(--first-color-lighter);
    transform: translateY(-2px);
  }
  .featured-project {
    background: linear-gradient(135deg, rgba(110, 87, 224, 0.03) 0%, rgba(255, 193, 7, 0.03) 100%);
    border: 1px solid var(--first-color-lighter);
  }
  .winner-badge {
    animation: badgeShine 3s ease-in-out infinite;
  }
  @keyframes badgeShine {
    0%, 100% { box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3); }
    50% { box-shadow: 0 4px 20px rgba(245, 158, 11, 0.5); }
  }
</style>

<script>
  // Speed up all inline demo videos
  document.querySelectorAll<HTMLVideoElement>(".demo-video").forEach((v) => {
    v.playbackRate = 2.5;
  });

  // Shared lightbox logic
  const lightbox = document.getElementById("video-lightbox");
  const lightboxVideo = document.getElementById("lightbox-video") as HTMLVideoElement;
  const closeBtn = document.getElementById("lightbox-close");

  document.querySelectorAll(".video-thumbnail").forEach((thumb) => {
    thumb.addEventListener("click", () => {
      const src = (thumb as HTMLElement).dataset.videoSrc;
      if (lightbox && lightboxVideo && src) {
        lightboxVideo.src = src;
        lightboxVideo.playbackRate = 2;
        lightbox.classList.remove("hidden");
        lightbox.classList.add("flex");
        document.body.style.overflow = "hidden";
      }
    });
  });

  function closeLightbox() {
    if (lightbox && lightboxVideo) {
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      lightboxVideo.pause();
      lightboxVideo.removeAttribute("src");
      document.body.style.overflow = "";
    }
  }

  closeBtn?.addEventListener("click", closeLightbox);
  lightbox?.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeLightbox();
  });
</script>
