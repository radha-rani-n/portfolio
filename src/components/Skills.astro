---
import "../styles/global.css";
import React from "../assets/react.svg";
import Html from "../assets/html5.svg";
import Css from "../assets/css.svg";
import Sass from "../assets/sass.svg";
import Mui from "../assets/mui.svg";
import Antd from "../assets/antdesign.svg";
import Mysql from "../assets/mysql.svg";
import Express from "../assets/express.svg";
import Git from "../assets/git.svg";
import Github from "../assets/github.svg";
import Knex from "../assets/knexdotjs.svg";
import Node from "../assets/nodedotjs.svg";
import Tailwind from "../assets/tailwindcss.svg";
import Typescript from "../assets/typescript.svg";
import Astro from "../assets/astro.svg";
import badge from "../assets/guarantee.png";
import Skill from "../components/Skill.astro";
import Clerk from "../assets/clerk.svg";
import Netlify from "../assets/netlify.svg";
import Heroku from "../assets/heroku.svg";
import Vercel from "../assets/vercel.svg";
import Postgresql from "../assets/postgresql.svg";
import Prisma from "../assets/prisma.svg";
const frontEndSkills = [
  { name: "Html", src: Html },
  { name: "Css", src: Css },
  { name: "React", src: React },
  { name: "Sass", src: Sass },
  { name: "Typescript", src: Typescript },
  { name: "Tailwind", src: Tailwind },
  { name: "Mui", src: Mui },
  { name: "Antd", src: Antd },
];
const backendSkills = [
  { name: "Knex", src: Knex },
  { name: "Mysql", src: Mysql },
  { name: "PostgreSQL", src: Postgresql },
  { name: "Prisma", src: Prisma },
  { name: "Express", src: Express },
  { name: "Node", src: Node },
];
const other = [
  { name: "Git", src: Git },
  { name: "Github", src: Github },
  { name: "Vercel", src: Vercel },
  { name: "Clerk", src: Clerk },
  { name: "Heroku", src: Heroku },
  { name: "Netlify", src: Netlify },
];
---

<section
  class="flex flex-col items-center justify-center gap-10 md:gap-16 my-20 md:my-32 pt-20 md:pt-24 px-6 md:px-0"
  id="skills"
>
  <h2 class="text-3xl md:text-4xl font-bold section-heading reveal">Skills</h2>

  <div class="reveal w-full">
    <h3 class="text-2xl md:text-3xl font-semibold text-center mb-4 md:mb-6 text-[var(--first-color-alt)]">Frontend</h3>
    <div class="flex gap-3 md:gap-4 flex-wrap justify-center stagger-children">
      {
        frontEndSkills.map((skill) => (
          <Skill src={skill.src} skillName={skill.name}  />
        ))
      }
    </div>
  </div>

  <div class="reveal w-full">
    <h3 class="text-2xl md:text-3xl font-semibold text-center mb-4 md:mb-6 text-[var(--first-color-alt)]">Backend</h3>
    <div class="flex gap-3 md:gap-4 flex-wrap justify-center stagger-children">
      {
        backendSkills.map((skill) => (
          <Skill src={skill.src} skillName={skill.name}  />
        ))
      }
    </div>
  </div>

  <div class="reveal w-full">
    <h3 class="text-2xl md:text-3xl font-semibold text-center mb-4 md:mb-6 text-[var(--first-color-alt)]">Other</h3>
    <div class="flex gap-3 md:gap-4 flex-wrap justify-center stagger-children">
      {
        other.map((skill) => (
          <Skill src={skill.src} skillName={skill.name}  />
        ))
      }
    </div>
  </div>
</section>
